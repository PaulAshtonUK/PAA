// Data will be loaded from JSON files
let data = [];

// Averages for color coding
const avgApproved = 88;
const avgOnTime = 59;

let sortCol = 0;
let sortDir = 1;
let filtered = [];

// Load and merge both JSON files
async function loadData() {
  try {
    document.getElementById('loading').style.display = 'block';
    
    // Replace these URLs with your actual S3 URLs
    const performanceUrl = 'https://paa-lpa-hub.s3.eu-west-2.amazonaws.com/lpa_performance.json';
    const dataUrl = 'https://paa-lpa-hub.s3.eu-west-2.amazonaws.com/lpa_data.json';
    
    // Fetch both files
    const [perfResponse, dataResponse] = await Promise.all([
      fetch(performanceUrl),
      fetch(dataUrl)
    ]);
    
    const performanceData = await perfResponse.json();
    const lpaData = await dataResponse.json();
    
    // Create lookup for lpa_data by LPA24CD
    const dataLookup = {};
    lpaData.forEach(row => {
      const [lpaCode, ladCode, name, housePrice, pop, address, greenBelt] = row;
      dataLookup[lpaCode] = { name, greenBelt };
    });
    
    // Merge performance with lpa_data
    // Result format: [name, appsDecided, pcApproved, pcOnTime, greenBelt]
    data = performanceData.map(row => {
      const [lpaCode, ladCode, perfName, appsDecided, pcApproved, pcOnTime] = row;
      const lpaInfo = dataLookup[lpaCode] || { name: perfName, greenBelt: 0 };
      
      return [
        lpaInfo.name,
        appsDecided,
        pcApproved,
        pcOnTime,
        lpaInfo.greenBelt
      ];
    });
    
    filtered = data.slice();
    
    document.getElementById('loading').style.display = 'none';
    render();
    document.querySelector('thead th').classList.add('sorted-asc');
    
  } catch (error) {
    console.error('Error loading data:', error);
    document.getElementById('loading').style.display = 'none';
    document.getElementById('noResults').style.display = 'block';
    document.getElementById('noResults').textContent = 'Error loading data. Please check your S3 URLs and CORS settings.';
  }
}

// Improved color functions for white background - softer pastels
function greenBeltColor(pct) {
  if (pct === 0) return '#f8f8f8';
  // Softer pastel greens: light mint to sage green
  const t = Math.min(pct / 100, 1);
  const r = Math.round(220 - (220 - 130) * t);
  const g = Math.round(240 - (240 - 180) * t);
  const b = Math.round(220 - (220 - 140) * t);
  return `rgb(${r},${g},${b})`;
}

function metricColor(val, avg) {
  if (val >= avg) {
    // Above average: soft pastel greens
    const t = Math.min((val - avg) / (100 - avg), 1);
    const r = Math.round(230 - (230 - 140) * t);
    const g = Math.round(245 - (245 - 190) * t);
    const b = Math.round(230 - (230 - 140) * t);
    return `rgb(${r},${g},${b})`;
  } else {
    // Below average: soft pastel reds
    const t = val / avg;
    const r = Math.round(250 - (250 - 230) * t);
    const g = Math.round(230 - (230 - 180) * t);
    const b = Math.round(230 - (230 - 180) * t);
    return `rgb(${r},${g},${b})`;
  }
}

function render() {
  const tbody = document.getElementById('tableBody');
  const empty = document.getElementById('noResults');
  const count = document.getElementById('rowCount');

  tbody.innerHTML = '';

  if (!filtered.length) {
    empty.style.display = 'block';
    count.textContent = '';
    return;
  }

  empty.style.display = 'none';
  count.textContent = `Showing ${filtered.length} of ${data.length} authorities`;

  filtered.forEach(row => {
    const [name, apps, approved, onTime, greenBelt] = row;
    const tr = document.createElement('tr');
    
    const approvedColor = metricColor(approved, avgApproved);
    const onTimeColor = metricColor(onTime, avgOnTime);
    const gbColor = greenBeltColor(greenBelt);
    const url = urlMap[name] || '#';

    // All text in colored cells is black for consistency
    const cellTextColor = '#000';

    tr.innerHTML = `
      <td class="name-cell"><a href="${url}" target="_blank" rel="noopener">${name}</a></td>
      <td class="apps-cell">${apps.toLocaleString()}</td>
      <td class="metric-cell" style="background: ${approvedColor}; color: ${cellTextColor}">${approved.toFixed(1)}%</td>
      <td class="metric-cell" style="background: ${onTimeColor}; color: ${cellTextColor}">${onTime.toFixed(1)}%</td>
      <td class="green-belt-cell" style="background: ${gbColor}; color: ${cellTextColor}">${(greenBelt * 100).toFixed(1)}%</td>
    `;
    tbody.appendChild(tr);
  });
}

function doSort() {
  filtered.sort((a, b) => {
    const va = a[sortCol];
    const vb = b[sortCol];
    return (typeof va === 'string' ? va.localeCompare(vb) : va - vb) * sortDir;
  });
}

function sortTable(col) {
  const ths = document.querySelectorAll('thead th');
  ths.forEach(th => th.classList.remove('sorted-asc', 'sorted-desc'));

  if (sortCol === col) {
    sortDir *= -1;
  } else {
    sortCol = col;
    sortDir = 1;
  }

  ths[col].classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
  doSort();
  render();
}

document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  filtered = data.filter(r => r[0].toLowerCase().includes(q));
  doSort();
  render();
});

