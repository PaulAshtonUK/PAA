<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LPA Performance Dashboard</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  
  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
    background: #fff;
    color: #1a1a1a;
  }

  .dashboard-wrap {
    background: #fff;
    width: 100%;
    max-width: 100%;
  }

  .dashboard-header {
    padding: 1rem 1rem 1rem;
    border-bottom: 1px solid #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dashboard-header h2 {
    font-size: 2.8rem;
    font-weight: 600;
    color: #111;
    margin: 0;
  }

  .dashboard-header p {
    font-size: 1rem;
    font-weight: 600;
    color: #888;
    margin: 0rem 0 0;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: #fcfcfc;
    border: 1px solid #e8e8e8;
    border-radius: 0px;
    padding: 0.45rem 0.85rem;
    gap: 0.5rem;
    min-width: 150px;
  }

  .search-box svg { flex-shrink: 0; color: #aaa; }

  .search-box input {
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 0.75rem;
    color: #333;
    outline: none;
    width: 100%;
  }

  .search-box input::placeholder { color: #bbb; }

  .scroll-container { overflow-x: auto; width: 100%; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  thead th {
    position: sticky;
    top: 0;
    background: #dddddd;
    padding: 0.7rem 1rem;
    text-align: left;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #000000;
    border-bottom: 2px solid #fff;
    border-right: 1px solid #fff;
    cursor: pointer;
    user-select: none;
    white-space: normal;
    line-height: 1.2;
    transition: color 0.15s;
  }

  thead th:last-child { border-right: none; }

  thead th:hover { color: #222; }

  thead th.sorted-asc,
  thead th.sorted-desc {
  background: #cccccc; /* change to any colour you like */
  color: #111111;       /* optional, makes text stand out */
}
 
  .sort-icons {
    display: inline-flex;
    flex-direction: column;
    margin-left: 5px;
    vertical-align: middle;
    opacity: 0.35;
    transition: opacity 0.15s;
    line-height: 1;
  }

  thead th:hover .sort-icons { opacity: 0.6; }
  thead th.sorted-asc .sort-icons,
  thead th.sorted-desc .sort-icons { opacity: 1; }
  .sort-icons span { font-size: 0.55rem; line-height: 1; display: block; }

  tbody tr {
    border-bottom: 1px solid #fff;
    transition: background 0.1s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: #f9f9f7; }

  tbody td {
    padding: 0.65rem 1rem;
    vertical-align: middle;
    color: #333;
    border-right: 1px solid #fff;
  }

  tbody td:last-child { border-right: none; }

  td.name-cell {
    width: 200px;
    max-width: 200px;
    background: #eeeeee;
    color: #333;
  }

  td.name-cell a {
    color: #000000;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }

  td.name-cell a:hover {
    color: #0f3d21;
    border-bottom-color: #1a5c32;
  }

  td.apps-cell {
    text-align: center;
    background: #f5f5f5;
    font-weight: 600;
    color: #333;
  }

  td.green-belt-cell,
  td.metric-cell {
    text-align: center;
    font-weight: 600;
  }

  .no-results {
    text-align: center;
    padding: 3rem 1rem;
    color: #aaa;
    font-size: 0.85rem;
  }

  .row-count {
    font-size: 0.75rem;
    color: #aaa;
    padding: 0.6rem 1.75rem;
    border-top: 1px solid #fff;
  }

  .loading {
    text-align: center;
    padding: 3rem 1rem;
    color: #888;
    font-size: 1rem;
  }

  /* Mobile responsive styles */
  @media (max-width: 768px) {
    .dashboard-header {
      padding: 1rem;
    }

    .dashboard-header h2 {
      font-size: 1.5rem;
    }

    .dashboard-header p {
      font-size: 0.75rem;
    }

    .search-box {
      min-width: 140px;
      padding: 0.35rem 0.65rem;
    }

    .search-box input {
      font-size: 0.7rem;
    }

    table {
      font-size: 0.7rem;
    }

    thead th {
      padding: 0.4rem 0.25rem;
      font-size: 0.6rem;
      letter-spacing: 0.02em;
    }

    /* Make data columns narrower */
    thead th:nth-child(2),
    thead th:nth-child(3),
    thead th:nth-child(4),
    thead th:nth-child(5),
    tbody td:nth-child(2),
    tbody td:nth-child(3),
    tbody td:nth-child(4),
    tbody td:nth-child(5) {
      width: 18%;
      max-width: 70px;
    }

    tbody td {
      padding: 0.4rem 0.25rem;
    }

    td.name-cell {
      width: 28%;
      max-width: 100px;
      font-size: 0.65rem;
    }

    td.apps-cell {
      font-size: 0.7rem;
    }

    td.green-belt-cell,
    td.metric-cell {
      font-size: 0.7rem;
    }

    .sort-icons {
      font-size: 0.45rem;
      margin-left: 2px;
    }

    .sort-icons span {
      font-size: 0.45rem;
    }

    .row-count {
      font-size: 0.7rem;
      padding: 0.5rem 1rem;
    }
  }
</style>
</head>
<body>

<div class="dashboard-wrap">
  <div class="dashboard-header">
    <div>
      <p>Click column headers to sort</p>
    </div>
    <div class="search-box">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="searchInput" placeholder="Filter authorities…">
    </div>
  </div>

  <div class="scroll-container">
    <table id="lpaTable">
      <thead>
        <tr>
          <th onclick="sortTable(0)">LPA <span class="sort-icons"><span>▲</span><span>▼</span></span></th>
          <th onclick="sortTable(1)">Apps Decided <span class="sort-icons"><span>▲</span><span>▼</span></span></th>
          <th onclick="sortTable(2)">% Apps Approved <span class="sort-icons"><span>▲</span><span>▼</span></span></th>
          <th onclick="sortTable(3)">% Apps Decided On Time <span class="sort-icons"><span>▲</span><span>▼</span></span></th>
          <th onclick="sortTable(4)">Green Belt Area <span class="sort-icons"><span>▲</span><span>▼</span></span></th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
    <div class="loading" id="loading">Loading data...</div>
    <div class="no-results" id="noResults" style="display:none">No authorities match your search.</div>
  </div>
  <div class="row-count" id="rowCount"></div>
</div>

<script>
// URL mapping will be populated from lpa_data.json
let urlMap = {};

// Data will be loaded from JSON files
let data = [];

// Averages for color coding
const avgApproved = 88;
const avgOnTime = 59;

let sortCol = 0;
let sortDir = 1;
let filtered = [];

// Load and merge both JSON files
async function loadData() {
  try {
    document.getElementById('loading').style.display = 'block';
    
    // Replace these URLs with your actual S3 URLs
    const performanceUrl = 'https://paa-lpa-hub.s3.eu-west-2.amazonaws.com/lpa_performance.json';
    const dataUrl = 'https://paa-lpa-hub.s3.eu-west-2.amazonaws.com/lpa_data.json';
    
    // Fetch both files
    const [perfResponse, dataResponse] = await Promise.all([
      fetch(performanceUrl),
      fetch(dataUrl)
    ]);
    
    const performanceData = await perfResponse.json();
    const lpaData = await dataResponse.json();
    
// Create lookup for lpa_data by LPA24CD and build urlMap
const dataLookup = {};
lpaData.forEach(row => {
  const [lpaCode, ladCode, name, housePrice, pop, address, greenBelt, lpaUrl, empty, paaUrl] = row;
  dataLookup[lpaCode] = { name, greenBelt };
  // Use PAA URL (index 9) for the URL mapping
  if (paaUrl) {
    urlMap[name] = paaUrl;
  }
});
    
    // Merge performance with lpa_data
    // Result format: [name, appsDecided, pcApproved, pcOnTime, greenBelt]
    data = performanceData.map(row => {
      const [lpaCode, ladCode, perfName, appsDecided, pcApproved, pcOnTime] = row;
      const lpaInfo = dataLookup[lpaCode] || { name: perfName, greenBelt: 0 };
      
      return [
        lpaInfo.name,
        appsDecided,
        pcApproved,
        pcOnTime,
        lpaInfo.greenBelt
      ];
    });
    
    filtered = data.slice();
    
    document.getElementById('loading').style.display = 'none';
    render();
    document.querySelector('thead th').classList.add('sorted-asc');
    
  } catch (error) {
    console.error('Error loading data:', error);
    document.getElementById('loading').style.display = 'none';
    document.getElementById('noResults').style.display = 'block';
    document.getElementById('noResults').textContent = 'Error loading data. Please check your S3 URLs and CORS settings.';
  }
}

// Improved color functions for white background - softer pastels
function greenBeltColor(pct) {
  if (pct === 0) return '#f8f8f8';
  // Softer pastel greens: light mint to sage green
  const t = Math.min(pct / 100, 1);
  const r = Math.round(220 - (220 - 130) * t);
  const g = Math.round(240 - (240 - 180) * t);
  const b = Math.round(220 - (220 - 140) * t);
  return `rgb(${r},${g},${b})`;
}

function metricColor(val, avg) {
  if (val >= avg) {
    // Above average: soft pastel greens
    const t = Math.min((val - avg) / (100 - avg), 1);
    const r = Math.round(230 - (230 - 140) * t);
    const g = Math.round(245 - (245 - 190) * t);
    const b = Math.round(230 - (230 - 140) * t);
    return `rgb(${r},${g},${b})`;
  } else {
    // Below average: soft pastel reds
    const t = val / avg;
    const r = Math.round(250 - (250 - 230) * t);
    const g = Math.round(230 - (230 - 180) * t);
    const b = Math.round(230 - (230 - 180) * t);
    return `rgb(${r},${g},${b})`;
  }
}

function render() {
  const tbody = document.getElementById('tableBody');
  const empty = document.getElementById('noResults');
  const count = document.getElementById('rowCount');

  tbody.innerHTML = '';

  if (!filtered.length) {
    empty.style.display = 'block';
    count.textContent = '';
    return;
  }

  empty.style.display = 'none';
  count.textContent = `Showing ${filtered.length} of ${data.length} authorities`;

  filtered.forEach(row => {
    const [name, apps, approved, onTime, greenBelt] = row;
    const tr = document.createElement('tr');
    
    const approvedColor = metricColor(approved, avgApproved);
    const onTimeColor = metricColor(onTime, avgOnTime);
    const gbColor = greenBeltColor(greenBelt);
    const url = urlMap[name] || '#';

    // All text in colored cells is black for consistency
    const cellTextColor = '#000';

    tr.innerHTML = `
      <td class="name-cell"><a href="${url}" target="_blank" rel="noopener">${name}</a></td>
      <td class="apps-cell">${apps.toLocaleString()}</td>
      <td class="metric-cell" style="background: ${approvedColor}; color: ${cellTextColor}">${approved.toFixed(1)}%</td>
      <td class="metric-cell" style="background: ${onTimeColor}; color: ${cellTextColor}">${onTime.toFixed(1)}%</td>
      <td class="green-belt-cell" style="background: ${gbColor}; color: ${cellTextColor}">${(greenBelt * 100).toFixed(1)}%</td>
    `;
    tbody.appendChild(tr);
  });
}

function doSort() {
  filtered.sort((a, b) => {
    const va = a[sortCol];
    const vb = b[sortCol];
    return (typeof va === 'string' ? va.localeCompare(vb) : va - vb) * sortDir;
  });
}

function sortTable(col) {
  const ths = document.querySelectorAll('thead th');
  ths.forEach(th => th.classList.remove('sorted-asc', 'sorted-desc'));

  if (sortCol === col) {
    sortDir *= -1;
  } else {
    sortCol = col;
    sortDir = 1;
  }

  ths[col].classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
  doSort();
  render();
}

document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  filtered = data.filter(r => r[0].toLowerCase().includes(q));
  doSort();
  render();
});

// Load data when page loads
loadData();
</script>

</body>
</html>
