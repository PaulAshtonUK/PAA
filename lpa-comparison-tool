<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LPA Performance Dashboard</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  
  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
    background: #fff;
    color: #1a1a1a;
  }

  .dashboard-wrap {
    background: #fff;
    width: 100%;
    max-width: 100%;
  }

  .dashboard-header {
    padding: 1rem 1rem 1rem;
    border-bottom: 1px solid #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dashboard-header h2 {
    font-size: 2.8rem;
    font-weight: 600;
    color: #111;
    margin: 0;
  }

  .dashboard-header p {
    font-size: 1rem;
    font-weight: 600;
    color: #888;
    margin: 0rem 0 0;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: #fcfcfc;
    border: 1px solid #e8e8e8;
    border-radius: 0px;
    padding: 0.45rem 0.85rem;
    gap: 0.5rem;
    min-width: 150px;
  }

  .search-box svg { flex-shrink: 0; color: #aaa; }

  .search-box input {
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 0.75rem;
    color: #333;
    outline: none;
    width: 100%;
  }

  .search-box input::placeholder { color: #bbb; }

  .scroll-container { overflow-x: auto; width: 100%; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  thead th {
    position: sticky;
    top: 0;
    background: #dddddd;
    padding: 0.7rem 1rem;
    text-align: left;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #000000;
    border-bottom: 2px solid #fff;
    border-right: 1px solid #fff;
    cursor: pointer;
    user-select: none;
    white-space: normal;
    line-height: 1.2;
    transition: color 0.15s;
  }

  thead th:last-child { border-right: none; }

  thead th:hover { color: #222; }

  thead th.sorted-asc,
  thead th.sorted-desc {
  background: #cccccc; /* change to any colour you like */
  color: #111111;       /* optional, makes text stand out */
}
 
  .sort-icons {
    display: inline-flex;
    flex-direction: column;
    margin-left: 5px;
    vertical-align: middle;
    opacity: 0.35;
    transition: opacity 0.15s;
    line-height: 1;
  }

  thead th:hover .sort-icons { opacity: 0.6; }
  thead th.sorted-asc .sort-icons,
  thead th.sorted-desc .sort-icons { opacity: 1; }
  .sort-icons span { font-size: 0.55rem; line-height: 1; display: block; }

  tbody tr {
    border-bottom: 1px solid #fff;
    transition: background 0.1s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: #f9f9f7; }

  tbody td {
    padding: 0.65rem 1rem;
    vertical-align: middle;
    color: #333;
    border-right: 1px solid #fff;
  }

  tbody td:last-child { border-right: none; }

  td.name-cell {
    width: 200px;
    max-width: 200px;
    background: #eeeeee;
    color: #333;
  }

  td.name-cell a {
    color: #000000;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }

  td.name-cell a:hover {
    color: #0f3d21;
    border-bottom-color: #1a5c32;
  }

  td.apps-cell {
    text-align: center;
    background: #f5f5f5;
    font-weight: 600;
    color: #333;
  }

  td.green-belt-cell,
  td.metric-cell {
    text-align: center;
    font-weight: 600;
  }

  .no-results {
    text-align: center;
    padding: 3rem 1rem;
    color: #aaa;
    font-size: 0.85rem;
  }

  .row-count {
    font-size: 0.75rem;
    color: #aaa;
    padding: 0.6rem 1.75rem;
    border-top: 1px solid #fff;
  }

  .loading {
    text-align: center;
    padding: 3rem 1rem;
    color: #888;
    font-size: 1rem;
  }

  /* Mobile responsive styles */
  @media (max-width: 768px) {
    .dashboard-header {
      padding: 1rem;
    }

    .dashboard-header h2 {
      font-size: 1.5rem;
    }

    .dashboard-header p {
      font-size: 0.75rem;
    }

    .search-box {
      min-width: 140px;
      padding: 0.35rem 0.65rem;
    }

    .search-box input {
      font-size: 0.7rem;
    }

    table {
      font-size: 0.7rem;
    }

    thead th {
      padding: 0.4rem 0.25rem;
      font-size: 0.6rem;
      letter-spacing: 0.02em;
    }

    /* Make data columns narrower */
    thead th:nth-child(2),
    thead th:nth-child(3),
    thead th:nth-child(4),
    thead th:nth-child(5),
    tbody td:nth-child(2),
    tbody td:nth-child(3),
    tbody td:nth-child(4),
    tbody td:nth-child(5) {
      width: 18%;
      max-width: 70px;
    }

    tbody td {
      padding: 0.4rem 0.25rem;
    }

    td.name-cell {
      width: 28%;
      max-width: 100px;
      font-size: 0.65rem;
    }

    td.apps-cell {
      font-size: 0.7rem;
    }

    td.green-belt-cell,
    td.metric-cell {
      font-size: 0.7rem;
    }

    .sort-icons {
      font-size: 0.45rem;
      margin-left: 2px;
    }

    .sort-icons span {
      font-size: 0.45rem;
    }

    .row-count {
      font-size: 0.7rem;
      padding: 0.5rem 1rem;
    }
  }
</style>
</head>
